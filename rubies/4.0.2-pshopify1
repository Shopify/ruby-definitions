# https://github.com/Shopify/ruby/compare/v4.0.2...Shopify:v4.0.2-pshopify1

# Based off v4.0.2, with the following changes:
#   * Allow auto-sync from Prism ruby-4.0
#   * Ensure fiber stack is freed in all cases, if the fiber is terminated (#16416)

install_package "openssl-3.0.19" "https://github.com/openssl/openssl/releases/download/openssl-3.0.19/openssl-3.0.19.tar.gz#fa5a4143b8aae18be53ef2f3caf29a2e0747430b8bc74d32d88335b94ab63072" openssl --if needs_openssl:1.0.2-3.x.x
install_git "ruby-4.0.2-pshopify1" "https://github.com/Shopify/ruby.git" "v4.0.2-pshopify1" autoconf enable_shared standard
